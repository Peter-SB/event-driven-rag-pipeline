# Copy to .env and fill in values before running docker-compose

# Postgres
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag
POSTGRES_PORT=5432

# RabbitMQ
RABBITMQ_USER=rag
RABBITMQ_PASS=rag
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Redpanda / Kafka
# Comma-separated broker addresses
REDPANDA_SERVERS=localhost:9092

# Event bus driver: "postgres" (homelab polling) or "redpanda" (production)
EVENT_BUS=postgres
MOCK_EMBEDDINGS=0

# Observability
OTEL_ENABLED=true

# Application database URL (used by API and workers directly)
DB_URL=postgresql://rag:rag@localhost:5432/rag
RABBITMQ_URL=amqp://rag:rag@localhost:5672/

# API port
API_PORT=8000

# Optional: remote OpenAI-compatible embedding endpoint (e.g. LM Studio on a
# homelab GPU machine). Leave EMBED_REMOTE_URL unset to disable — the GPU
# worker falls back to its local model automatically when this is off/unreachable.
EMBED_REMOTE_URL=http://100.105.195.60:1234/v1
EMBED_REMOTE_API_KEY=
EMBED_REMOTE_TIMEOUT_S=10.0
EMBED_REMOTE_HEALTH_INTERVAL_S=30.0
