        {
            "id": 15,
            "title": "Total % Embedded",
            "description": "Percentage of all chunks (body + title + summary) that have a stored embedding. Shows 'No data' if any chunk table does not yet exist.",
            "type": "stat",
            "datasource": {
                "type": "postgres",
                "uid": "postgres-ds"
            },
            "gridPos": {
                "h": 5,
                "w": 6,
                "x": 0,
                "y": 19
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "postgres-ds"
                    },
                    "rawQuery": true,
                    "rawSql": "SELECT CASE WHEN SUM(total) = 0 THEN 0 ELSE ROUND(SUM(embedded) * 100.0 / SUM(total), 1) END AS \"Total % Embedded\"\nFROM (\n  SELECT COUNT(*) AS total, COUNT(*) FILTER (WHERE embedding IS NOT NULL) AS embedded\n    FROM posts_${library_id}_chunks_body_baai_bge_base_en_v1_5\n  UNION ALL\n  SELECT COUNT(*), COUNT(*) FILTER (WHERE embedding IS NOT NULL)\n    FROM posts_${library_id}_chunks_title_baai_bge_small_en_v1_5\n  UNION ALL\n  SELECT COUNT(*), COUNT(*) FILTER (WHERE embedding IS NOT NULL)\n    FROM posts_${library_id}_chunks_summary_title_qwen3_embedding_0_6b_q8_0_gguf\n) sub",
                    "format": "table",
                    "refId": "A"
                }
            ],
            "options": {
                "reduceOptions": {
                    "values": false,
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": ""
