        {
            "id": 10,
            "title": "Posts — Cumulative Growth (All Time)",
            "description": "Running total of posts over time, bucketed by day using added_at. Ignores the dashboard time picker — always shows the full history.",
            "type": "timeseries",
            "datasource": { "type": "postgres", "uid": "postgres-ds" },
            "gridPos": { "h": 12, "w": 24, "x": 0, "y": 15 },
            "targets": [
                {
                    "datasource": { "type": "postgres", "uid": "postgres-ds" },
                    "rawQuery": true,
                    "rawSql": "WITH daily AS (\n  SELECT\n    date_trunc('day', added_at) AS day,\n    COUNT(*)                                                                          AS total,\n    COUNT(*) FILTER (WHERE NOT is_deleted AND NOT is_archived)                        AS active,\n    COUNT(*) FILTER (WHERE NOT is_deleted AND NOT is_archived AND is_read)            AS read_posts\n  FROM posts_${library_id}\n  WHERE added_at IS NOT NULL\n  GROUP BY 1\n)\nSELECT\n  day                                                                                           AS \"time\",\n  SUM(total)      OVER (ORDER BY day ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW)         AS \"Total\",\n  SUM(active)     OVER (ORDER BY day ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW)         AS \"Active\",\n  SUM(read_posts) OVER (ORDER BY day ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW)         AS \"Read\"\nFROM daily\nORDER BY 1",
                    "format": "time_series",
                    "refId": "A"
                }
            ],
            "options": {
                "tooltip": { "mode": "multi", "sort": "none" },
                "legend": {
                    "calcs": ["last"],
                    "displayMode": "list",
                    "placement": "bottom",
                    "showLegend": true
                }
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 8,
                        "gradientMode": "none",
                        "showPoints": "never",
                        "spanNulls": true,
                        "drawStyle": "line",
                        "lineInterpolation": "linear"
                    }
                },
                "overrides": [
                    {
                        "matcher": { "id": "byName", "options": "Total" },
                        "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
                    },
                    {
                        "matcher": { "id": "byName", "options": "Active" },
                        "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
                    },
                    {
                        "matcher": { "id": "byName", "options": "Read" },
                        "properties": [{ "id": "color", "value": { "fixedColor": "dark-green", "mode": "fixed" } }]
                    }
                ]
            }
        }
    ]
