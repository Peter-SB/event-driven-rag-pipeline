        {
            "id": 6,
            "title": "Read / Active Ratio",
            "description": "Percentage of active posts that have been read",
            "type": "stat",
            "datasource": { "type": "postgres", "uid": "postgres-ds" },
            "gridPos": { "h": 5, "w": 8, "x": 16, "y": 0 },
            "targets": [
                {
                    "datasource": { "type": "postgres", "uid": "postgres-ds" },
                    "rawQuery": true,
                    "rawSql": "SELECT CASE WHEN COUNT(*) FILTER (WHERE NOT is_deleted AND NOT is_archived) = 0 THEN 0.0 ELSE ROUND(COUNT(*) FILTER (WHERE NOT is_deleted AND NOT is_archived AND is_read) * 100.0 / COUNT(*) FILTER (WHERE NOT is_deleted AND NOT is_archived), 1) END AS \"Ratio\" FROM posts_${library_id}",
                    "format": "table",
                    "refId": "A"
                }
            ],
            "options": {
                "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
                "orientation": "auto",
                "textMode": "auto",
                "colorMode": "background",
                "graphMode": "none",
                "justifyMode": "center",
                "wideLayout": true,
                "showPercentChange": false
            },
            "fieldConfig": {
                "defaults": {
                    "color": { "mode": "thresholds" },
                    "unit": "percent",
                    "decimals": 1,
                    "min": 0,
                    "max": 100,
                    "mappings": [],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            { "color": "red", "value": null },
                            { "color": "yellow", "value": 25 },
                            { "color": "green", "value": 75 }
                        ]
                    }
                },
                "overrides": []
